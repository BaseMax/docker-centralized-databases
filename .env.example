# ─────────────────────────────────────────────────────────────────────────────
# Docker Centralized Databases – Environment Configuration
# Copy this file to .env and fill in strong, unique values before first start.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Active profiles ───────────────────────────────────────────────────────────
# Comma-separated list of services to start.
# Available: mariadb, phpmyadmin, postgres, pgadmin, adminer, redis, redisinsight
#
# Examples:
#   Full stack     : mariadb,phpmyadmin,postgres,pgadmin,adminer,redis,redisinsight
#   MariaDB only   : mariadb,phpmyadmin
#   PostgreSQL only: postgres,pgadmin
#   Redis only     : redis,redisinsight
#   All + Adminer  : mariadb,postgres,redis,adminer,redisinsight
COMPOSE_PROFILES=mariadb,phpmyadmin,redis,redisinsight

# ── MariaDB ───────────────────────────────────────────────────────────────────
# Required when 'mariadb' profile is active.
MARIADB_ROOT_PASSWORD=change_this_strong_root_password

# Default database and unprivileged user created on first start
MARIADB_DATABASE=app
MARIADB_USER=app_user
MARIADB_PASSWORD=change_this_strong_user_password

# Host binding (127.0.0.1 = localhost only | 0.0.0.0 = all interfaces)
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306

# ── phpMyAdmin ────────────────────────────────────────────────────────────────
# Required when 'phpmyadmin' profile is active.
# Max size for SQL file imports (sets upload_max_filesize & post_max_size)
PMA_MAX_UPLOAD_SIZE=256M
PMA_MAX_EXECUTION_TIME=600
PMA_MEMORY_LIMIT=512M
PHPMYADMIN_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Required when 'postgres' profile is active.
POSTGRES_DB=app
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_this_strong_postgres_password

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── pgAdmin 4 ─────────────────────────────────────────────────────────────────
# Required when 'pgadmin' profile is active.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_this_strong_pgadmin_password
PGADMIN_PORT=5050

# ── Adminer ───────────────────────────────────────────────────────────────────
# Required when 'adminer' profile is active.
# Default server pre-filled on the login form ('mariadb' or 'postgres')
ADMINER_DEFAULT_SERVER=mariadb
ADMINER_PORT=8081

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required when 'redis' profile is active.
REDIS_PASSWORD=change_this_strong_redis_password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Redis Insight ─────────────────────────────────────────────────────────────
# Required when 'redisinsight' profile is active.
REDISINSIGHT_PORT=5540
