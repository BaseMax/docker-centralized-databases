# ─────────────────────────────────────────────────────────────────────────────
# Docker Centralized Databases – Environment Configuration
# Copy this file to .env and fill in strong, unique values before first start.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MariaDB ───────────────────────────────────────────────────────────────────
# Root password (used only for admin / phpMyAdmin; do not use in app connections)
MARIADB_ROOT_PASSWORD=change_this_strong_root_password

# Default database and unprivileged user created on first start
MARIADB_DATABASE=app
MARIADB_USER=app_user
MARIADB_PASSWORD=change_this_strong_user_password

# Host binding for the MariaDB port
# 127.0.0.1 = localhost only (recommended)
# 0.0.0.0  = all interfaces (only if you need remote direct access)
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_strong_redis_password

# Host binding for the Redis port
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── phpMyAdmin ────────────────────────────────────────────────────────────────
# Maximum size for SQL file imports (sets upload_max_filesize & post_max_size)
PMA_MAX_UPLOAD_SIZE=256M

# PHP max_execution_time in seconds (for large import operations)
PMA_MAX_EXECUTION_TIME=600

# PHP memory_limit
PMA_MEMORY_LIMIT=512M

# Port exposed on localhost for the phpMyAdmin web UI
PHPMYADMIN_PORT=8080

# ── Redis Insight ─────────────────────────────────────────────────────────────
# Port exposed on localhost for the Redis Insight web UI
REDISINSIGHT_PORT=5540
